{
  "name": "mastergo-magic-mcp",
  "command": "npx",
  "args": ["-y", "@mastergo/magic-mcp", "--token=${MASTERGO_TOKEN}", "--url=https://mastergo.com"],
  "real_protocol_version": "2024-11-05",
  "real_framing": "jsonl",
  "env": {
    "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/"
  },
  "idle_timeout": "30s",
  "startup_timeout": "30s",
  "call_timeout": "180s",
  "log_file": "/tmp/lazy-mcp-wrapper-mastergo.log"
}
